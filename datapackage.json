{
    "profile": "data-package",
    "name": "transitions-2050",
    "title": "Transition-s 2050",
    "description": "Implementation of the electricity, gas, and hydrogen scenarios described in Transition-s 2050 / ADEME",
    "version": "1.0.0",
    "contributors":[
        {
            "title": "Joanna Schlesinger",
            "email": "joanna.schlesinger@minesparis.psl.eu"          
        },{
            "title": "Romain Sacchi",
             "email": "romain.sacchi@psi.ch"
        },{
            "title": "Juliana Steinbach",
             "email": "juliana.steinbach@minesparis.psl.eu"
        },{
            "title": "Thomas Beaussier",
             "email": "thomas.beaussier@minesparis.psl.eu"
		},{
            "title": "Paula Perez-Lopez",
             "email": "paula;perez_lopez@minesparis.psl.eu"
        },{
            "title": "Gonzalo Puig-Samper",
             "email": "gonzalo.puig-samper@list.lu"
        }
    ],
    "dependencies": {
        "premise": ">=2.2.6"
    },
    "ecoinvent": {
        "version": "3.9.1",
        "system model": "cut-off"
    },
    "scenarios description": {
        "S1": "Frugal generation: The transition is driven\nmostly by sobriety and constraint",
		"S2": "Territorial cooperation: The society transformation\nis based on a shared governance and\non territorialization strategies",
		"S3 Renew": "- Green technologies renewables: The transition\nis based on innovation and development\nof low carbon technologies, especially renewable energies",  
        "S3 Nuc": "Green technologies nuclear: The transition\nis based on innovation and development\nof low carbon technologies, especially nuclear energy",  
        "S4": "Repairing bet: The transition\nrelies highly on new technologies development,\nwithout any society lifestyle changes."
    },
    "source": "https://www.ademe.fr/les-futurs-en-transition/",
    "licenses": [{
    "id": "CC0-1.0",
    "title": "CC0 1.0",
    "url": "https://creativecommons.org/publicdomain/zero/1.0/"
      }],
    "scenarios": [
        "S1",
        "S2",
        "S3 Renew",
        "S3 Nuc",
        "S4"
    ],
    "resources": [
        {
            "path": "scenario_data/scenario_data.csv",
            "profile": "tabular-data-resource",
            "name": "scenario_data",
            "format": "csv",
            "mediatype": "text/csv",
            "encoding": "utf-8-sig",
            "schema": {
                "fields": [
                    {
                        "name": "scenario",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "region",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "variables",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "unit",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "2020",
                        "type": "number",
                        "format": "default"
                    },
                    {
                        "name": "2030",
                        "type": "number",
                        "format": "default"
                    },
                    {
                        "name": "2050",
                        "type": "number",
                        "format": "default"
                    }
                ],
                "missingValues": [
                    ""
                ]
            }
        },
        {
            "path": "inventories/lci-Tr2050.xlsx",
            "profile": "data-resource",
            "name": "inventories",
            "format": "csv",
            "mediatype": "text/csv",
            "encoding": "utf-8",
            "schema": {
                "fields": [
                    {
                        "name": "name",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "amount",
                        "type": "number",
                        "format": "default"
                    },
                    {
                        "name": "database",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "location",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "categories",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "unit",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "type",
                        "type": "string",
                        "format": "default"
                    },
                    {
                        "name": "reference product",
                        "type": "string",
                        "format": "default"
                    }
                ],
                "missingValues": [
                    ""
                ]
            }
        },
        {
            "path": "configuration_file/config.yaml",
            "profile": "data-resource",
            "name": "config",
            "format": "yaml",
            "mediatype": "text/yaml",
            "encoding": "utf-8"
        }
    ]
}